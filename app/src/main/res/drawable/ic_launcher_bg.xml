<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="300"
                android:startColor="@color/cv_paper_top"
                android:centerColor="@color/cv_paper_mid"
                android:endColor="@color/cv_paper_bottom" />
        </shape>
    </item>
    <!-- teal wash upper-left -->
    <item
        android:width="80dp"
        android:height="80dp"
        android:gravity="top|start"
        android:left="-28dp"
        android:top="-20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:startColor="#B378D6C9"
                android:endColor="#0078D6C9" />
        </shape>
    </item>
    <!-- apricot wash lower-right -->
    <item
        android:width="76dp"
        android:height="76dp"
        android:gravity="bottom|end"
        android:right="-24dp"
        android:bottom="-20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="38dp"
                android:startColor="#A6F4BE8A"
                android:endColor="#00F4BE8A" />
        </shape>
    </item>
</layer-list>
