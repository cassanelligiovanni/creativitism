<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:contentDescription="@string/app_icon_description"
        tools:src="@android:drawable/sym_def_app_icon" />

    <TextView
        android:id="@+id/appName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        tools:text="Example App" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addToCreativeButton"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/add_to_creative"
        app:icon="@drawable/ic_tilde"
        app:iconTint="@color/cv_teal" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addToSoulSuckingButton"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/add_to_blocked"
        app:icon="@drawable/ic_block"
        app:iconTint="@color/cv_sienna" />

</LinearLayout>
