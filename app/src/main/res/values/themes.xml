<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Glass-over-paper theme. Color tokens auto-switch via values-night/colors.xml. -->
    <style name="Base.Theme.Creativitism" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cv_teal</item>
        <item name="colorOnPrimary">@color/cv_on_teal</item>
        <item name="colorPrimaryContainer">@color/cv_teal</item>
        <item name="colorOnPrimaryContainer">@color/cv_on_teal</item>
        <item name="colorSecondary">@color/cv_muted</item>
        <item name="colorOnSecondary">@color/cv_surface</item>
        <item name="colorError">@color/cv_error</item>
        <item name="colorOnError">@color/cv_on_error</item>
        <item name="android:colorBackground">@color/cv_surface</item>
        <item name="colorOnBackground">@color/cv_ink</item>
        <item name="colorSurface">@color/cv_surface</item>
        <item name="colorOnSurface">@color/cv_ink</item>
        <item name="colorOnSurfaceVariant">@color/cv_muted</item>
        <item name="colorOutline">@color/cv_muted</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Creativitism" parent="Base.Theme.Creativitism" />

    <!-- "Take a breath" sheet: translucent activity, frost drawn by the layout -->
    <style name="Theme.Creativitism.Interstitial">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Theme for the transparent proxy activity -->
    <style name="Theme.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
